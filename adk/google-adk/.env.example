# Memoral ADK Service - Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# GOOGLE AI CONFIGURATION (Required)
# ===========================================
# Get your API key from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=AIzaSyDRKS9N6chhMg3yhVECr365xRA489-dbyk

# Google Cloud Configuration (Optional - for advanced features)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# Gemini model to use (optional - defaults to gemini-2.0-flash-exp)
GEMINI_MODEL=gemini-2.0-flash-exp

# Model temperature for response generation (0.0 - 1.0)
GEMINI_TEMPERATURE=0.7

# ===========================================
# SERVICE CONFIGURATION
# ===========================================
# Port for the FastAPI server (default: 5000)
PORT=5000

# API host binding
API_HOST=0.0.0.0

# Environment (development, staging, production)
ENVIRONMENT=development

# Debug mode
DEBUG=true

# ===========================================
# BACKEND CONNECTION (Required)
# ===========================================
# URL of the Node.js backend API
BACKEND_API_URL=http://localhost:8000

# ===========================================
# DATABASE (Optional - using backend API instead)
# ===========================================
DATABASE_URL=postgresql://user:password@localhost:5432/memorii_db

# ===========================================
# LOGGING
# ===========================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ===========================================
# EXTERNAL SERVICES (Optional)
# ===========================================
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
SENDGRID_API_KEY=your-sendgrid-key

# ===========================================
# FEATURE FLAGS
# ===========================================
ENABLE_NOTIFICATIONS=true
ENABLE_ANALYTICS=true
ENABLE_WEBSOCKET=true
