# Supabase Configuration
# Get these from your Supabase project settings: Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# AI API Keys (used by voice assistant endpoint /api/ai/voice)
# Claude (primary) — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
# Gemini (fallback) — get from aistudio.google.com
GEMINI_API_KEY=AIza...

# Server Configuration
PORT=8000
FRONTEND_URL=http://localhost:3000
NODE_ENV=development
